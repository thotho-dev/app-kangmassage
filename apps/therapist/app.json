{
  "expo": {
    "name": "Kang Massage Mitra",
    "slug": "pijat-therapist",
    "version": "2.0.1",
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.rmhbgr.kangmassagetherapist",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-km.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withNotifeeMavenRepo",
      "./plugins/withLockScreenActivity",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-notif.png",
          "sounds": [
            "assets/raw/sound_expo.mp3",
            "assets/raw/sound_notifee.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Kang Massage Mitra to use your location even when the app is in background to receive nearby orders."
        }
      ],
      "expo-secure-store",
      "expo-font",
      ["expo-build-properties", {
        "android": {
          "useLegacyPackaging": true,
          "buildArchs": ["armeabi-v7a", "arm64-v8a", "x86_64"],
          "minSdkVersion": 24,
          "compileSdkVersion": 35,
          "targetSdkVersion": 35
        }
      }]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ebf580f7-7482-41e0-b221-aa2495fc4f3e"
      }
    },
    "owner": "rmhbgr"
  }
}
