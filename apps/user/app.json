{
  "expo": {
    "name": "Kang Massage",
    "slug": "kang-massage-customer",
    "version": "1.0.0",
    "icon": "./assets/icon-app-user.png",
    "android": {
      "package": "com.thotho.kangmassage.user",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-app-user.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "scheme": "kangmassage",
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18ef24ef-7af9-4c07-aad0-8f7e5251a618"
      }
    },
    "owner": "kang-massage"
  }
